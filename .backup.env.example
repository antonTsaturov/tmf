# ─────────────────────────────────────────────────────────────────────────────
# Backup Configuration
# Copy this file to backup.env and fill in the values.
# This file should NOT be committed to git!
# ─────────────────────────────────────────────────────────────────────────────

# ── Database Connection ──────────────────────────────────────────────────────
DB_HOST=31.169.124.166
DB_PORT=5432
DB_NAME=tmf
DB_USER=postgres
DB_PASSWORD=your_database_password_here

# ── Source S3 (production data to backup) ────────────────────────────────────
SOURCE_S3_BUCKET=tmf

# ── Backup S3 Destination (SEPARATE bucket!) ────────────────────────────────
# Create a dedicated backup bucket: tmf-backups
BACKUP_S3_BUCKET=s3://tmf-backups
BACKUP_S3_ACCESS_KEY=your_backup_s3_access_key
BACKUP_S3_SECRET_KEY=your_backup_s3_secret_key
BACKUP_S3_ENDPOINT=https://storage.yandexcloud.net

# ── Local Backup Storage ────────────────────────────────────────────────────
BACKUP_LOCAL_DIR=/backups

# ── Retention Policies ──────────────────────────────────────────────────────
BACKUP_RETENTION_DAYS=30
BACKUP_S3_RETENTION_DAYS=90

# ── Notifications (optional) ────────────────────────────────────────────────
# Slack webhook URL for backup status alerts
SLACK_WEBHOOK_URL=

# ── Cron Schedule ───────────────────────────────────────────────────────────
# Default: every day at 3:00 AM
# Add to crontab: 0 3 * * * /scripts/backup.sh >> /var/log/backup.log 2>&1
