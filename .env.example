# Environment Configuration Template
# This file is for version control - DO NOT commit actual secrets!
# Copy this to .env.local and fill in actual values

# 🔐 JWT Configuration
# Generate a secure secret with: openssl rand -base64 32
# Minimum 32 characters in production
JWT_SECRET=fill-in-your-secret-key-at-least-32-characters-long

# 📊 Database Configuration
# PostgreSQL connection string
# Format: postgresql://username:password@hostname:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/manpremotmf

# ☁️ Yandex Cloud Configuration
# Path to IAM service account key JSON file
YC_IAM_KEY_PATH=./ya_cloud-iam_key.json

# 🏢 Application Environment
# Options: development | production | test
NODE_ENV=development

# 🌐 Public API Base URL
# Used by client-side code to call API endpoints
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# 🌐 CORS Configuration
# Comma-separated list of allowed origins for cross-origin requests
# In development: automatically allows localhost
# In production: explicitly list your frontend domains
CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# 📁 File Security Configuration
# Maximum file upload size in bytes (default: 104857600 = 100MB)
# Examples:
#   50 MB: 52428800
#   100 MB: 104857600
#   500 MB: 524288000
MAX_FILE_SIZE=104857600

# Email notifications by Resend service (https://resend.com)
RESEND_API_KEY=resend-api-key
EMAIL_FROM=noreply@domen-name
APP_URL=https://domen-name