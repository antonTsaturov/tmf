# Environment Configuration Template
# This file is for version control - DO NOT commit actual secrets!
# Copy this to .env.local and fill in actual values

# 🔐 JWT Configuration
# Generate a secure secret with: openssl rand -base64 32
# Minimum 32 characters in production
JWT_SECRET=fill-in-your-secret-key-at-least-32-characters-long

# 📊 Database Configuration
# PostgreSQL connection string
# Format: postgresql://username:password@hostname:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/manpremotmf

# ☁️ Yandex Cloud Configuration
# Path to IAM service account key JSON file
YC_IAM_KEY_PATH=./ya_cloud-iam_key.json

# 🏢 Application Environment
# NOTE: Don't set NODE_ENV manually — Next.js manages this automatically
# Use 'development' with `next dev`, 'production' with `next build/start`
# NODE_ENV=development

# 🌐 Public API Base URL
# Used by client-side code to call API endpoints
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# 🌐 CORS Configuration
# Comma-separated list of allowed origins for cross-origin requests
# In development: automatically allows localhost
# In production: explicitly list your frontend domains
CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# 📁 File Security Configuration
# Maximum file upload size in bytes (default: 104857600 = 100MB)
# Examples:
#   50 MB: 52428800
#   100 MB: 104857600
#   500 MB: 524288000
MAX_FILE_SIZE=104857600

# Email notifications by Resend service (https://resend.com)
RESEND_API_KEY=resend-api-key
EMAIL_FROM=noreply@domen-name
APP_URL=https://domen-name
# (API Key) для доступа к эндпоинту app/api/cron/digest/route.ts
CRON_SECRET=openssl-rand-base6432-output



# ─────────────────────────────────────────────────────────────────────────────
# Backup Configuration
# ─────────────────────────────────────────────────────────────────────────────

# ── Database Connection ──────────────────────────────────────────────────────
DB_HOST=db-ip-adress
DB_PORT=db-port
DB_NAME=tmf
DB_USER=postgres
DB_PASSWORD=your_database_password_here

# ── Source S3 (production data to backup) ────────────────────────────────────
SOURCE_S3_BUCKET=tmf

# ── Backup S3 Destination (SEPARATE bucket!) ────────────────────────────────
# Create a dedicated backup bucket: tmf-backups
BACKUP_S3_BUCKET=s3://tmf-backups
BACKUP_S3_ACCESS_KEY=your_backup_s3_access_key
BACKUP_S3_SECRET_KEY=your_backup_s3_secret_key
BACKUP_S3_ENDPOINT=https://storage.yandexcloud.net

# ── Local Backup Storage ────────────────────────────────────────────────────
BACKUP_LOCAL_DIR=/backups

# ── Retention Policies ──────────────────────────────────────────────────────
BACKUP_RETENTION_DAYS=30
BACKUP_S3_RETENTION_DAYS=90

# ── Notifications (optional) ────────────────────────────────────────────────
# Slack webhook URL for backup status alerts
SLACK_WEBHOOK_URL=

# ── Cron Schedule ───────────────────────────────────────────────────────────
# Default: every day at 3:00 AM
# Add to crontab: 0 3 * * * /scripts/backup.sh >> /var/log/backup.log 2>&1
